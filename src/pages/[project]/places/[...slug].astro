---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import { readFileSync } from 'fs';
import { getProjects, getProjectConfig } from '../../../utils/config.js';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { slugify } from '../../../utils/config.js';

export async function getStaticPaths() {
  const places = await getCollection('places');
  const projects = getProjects();
  const paths = [];
  for (const project of projects) {
    places.forEach(place => {
      paths.push({
        params: { project: project.slug, slug: place.id },
        props: { place },
      });
    });
  }
  return paths;
}

const { project } = Astro.params;
const { place } = Astro.props;
const { Content } = await render(place);
const projectConfig = await getProjectConfig(project);

const relationships = JSON.parse(
  readFileSync('./src/data/relationships.json', 'utf-8')
);
const scenesAtLocation = relationships.locationScenes[place.id] || [];
const mentionedIn = relationships.mentionedIn[place.id] || [];
const mentionedInOnly = mentionedIn.filter(
  m => !scenesAtLocation.some(a => a.slug === m.slug)
);
const allImages = import.meta.glob('/src/content/places/**/*.{jpg,png,webp,gif,svg}', { eager: true });
const placeImage = place.data.image
  ? allImages[`/src/content/places/${place.id}/${place.data.image}`]?.default
  : null;

---

<SiteLayout
  title={`${place.data.name} — ${projectConfig.title}`}
  backLink={`/${project}/places`}
  backLabel="Places"
>
  <main class="entity-page">
    <h1>{place.data.name}</h1>

    <div class="entity-meta">
      {place.data.subtype && (
        <p><strong>Type:</strong> {place.data.subtype}</p>
      )}
      {place.data.function && (
        <p><strong>Function:</strong> {place.data.function}</p>
      )}
      {place.data.scope && (
        <p><strong>Scope:</strong> {place.data.scope}</p>
      )}
      {place.data.status && (
        <p><strong>Status:</strong> {place.data.status}</p>
      )}
      {place.data.location && (
        <p><strong>Location:</strong> {place.data.location}</p>
      )}
      {place.data.aliases && place.data.aliases.length > 0 && (
        <p><strong>Also known as:</strong> {place.data.aliases.join(', ')}</p>
      )}
    </div>

    {placeImage && (
      <div class="entity-portrait">
        <Image
          src={placeImage}
          alt={place.data.image_alt ?? ''}
          width={600}
          height={400}
        />
      </div>
    )}

    <div class="entity-prose">
      <Content />
    </div>

    {scenesAtLocation.length > 0 && (
      <div class="entity-appearances">
        <h2>Scenes at This Location</h2>
        <ul>
          {scenesAtLocation.map(scene => (
            <li>
              <a href={`/${project}/stories/${scene.storySlug}/scenes/${scene.slug}`}>
                {scene.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {mentionedInOnly.length > 0 && (
      <div class="entity-appearances">
        <h2>Mentioned In</h2>
        <ul>
          {mentionedInOnly.map(scene => (
            <li>
              <a href={`/${project}/stories/${scene.storySlug}/scenes/${scene.slug}`}>
                {scene.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {place.data.tags && place.data.tags.length > 0 && (
      <div class="entity-tags">
        <h2>Tags</h2>
        <ul>
          {place.data.tags.map(tag => (
            <li class="tag">
              <a href={`/${project}/tags/${slugify(tag)}`}>{tag}</a>
            </li>
          ))}
        </ul>
      </div>
    )}

  </main>
</SiteLayout>